{
  "manifest_version": 3,
  "name": "Cold Outreach Capture",
  "version": "1.0.0",
  "description": "Local-only manual evidence capture for Cold Outreach OS.",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cold Outreach Capture",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/selection.js"],
      "run_at": "document_idle"
    }
  ]
}
