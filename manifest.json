{
  "manifest_version": 3,
  "name": "Cold Outreach Capture",
  "version": "0.1.0",
  "description": "Manual evidence capture tool for contact and company extraction.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/selection.js"],
      "run_at": "document_idle"
    }
  ]
}
